PORT=3001

# MongoDB — use Atlas free tier: https://cloud.mongodb.com
# Or local: mongodb://localhost:27017/dailylog
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/daily-logs?retryWrites=true&w=majority

# Generate a strong random string: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Google OAuth — https://console.cloud.google.com
# APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# Authorized redirect URI: http://localhost:3001/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Frontend URL (for redirects after login)
FRONTEND_URL=http://localhost:3000

# Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
